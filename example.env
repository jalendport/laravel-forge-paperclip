# laravel-forge-paperclip configuration — copy to `.env` and fill in.
#
#   cp example.env .env
#
# On Forge, set these in the site's Environment editor instead; Forge writes
# them to `.env` in the site root, which docker-compose.yml reads automatically.
# The real `.env` is gitignored and never committed.
#
# NOTE: LLM provider API keys (Anthropic, OpenAI, Gemini, …) are intentionally
# NOT set here. Create them in Paperclip's Secrets UI (Company Settings →
# Secrets) and bind them per agent — they stay encrypted at rest and out of
# this file. See the README.

# ── Required ────────────────────────────────────────────────────────────────
# Public URL Paperclip is reached at: your server's Tailscale MagicDNS name,
# over HTTPS (served by `tailscale serve`). No scheme other than https, no
# trailing slash.
PAPERCLIP_PUBLIC_URL=https://your-server.your-tailnet.ts.net

# Better Auth session secret.
# Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=

# Master key that encrypts every secret stored in the Secrets UI.
# Generate with: openssl rand -base64 32
#
# !! STORE THIS IN YOUR PASSWORD MANAGER !!
# It is NOT included in database or data-volume backups. Without it, restored
# secrets cannot be decrypted. Rotating it orphans all existing secrets.
PAPERCLIP_SECRETS_MASTER_KEY=

# PostgreSQL password, used by both the `db` service and DATABASE_URL.
# Generate with: openssl rand -base64 24
#
# !! SET ONCE BEFORE THE FIRST DEPLOY !!
# Changing it after the db volume is initialized breaks auth until you reset
# the volume.
POSTGRES_PASSWORD=

# ── Deployment posture (sane defaults; change only if you know why) ──────────
# Login required (Better Auth), private (Tailscale/LAN/VPN) exposure, and
# strict secret-reference enforcement for sensitive env keys.
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=private
PAPERCLIP_SECRETS_STRICT_MODE=true

# ── Database tuning (all optional) ───────────────────────────────────────────
# The `db` service auto-tunes Postgres to the memory/CPU available to the
# container at startup (cgroup limit when set, host total otherwise). You do NOT
# need to set anything here — defaults scale from a 1GB box to a 128GB box.
# Uncomment a line only to pin a value or reshape the formulas. See the README
# "Database tuning" section. Preview the computed values without starting the DB:
#   docker compose run --rm -e PG_TUNE_PRINT_ONLY=1 db
#
# /dev/shm size for Postgres parallel-query dynamic shared memory (compose-level).
#POSTGRES_SHM_SIZE=1g
#
# Pin individual Postgres parameters (override always wins; computed value is
# then not applied). Use Postgres units, e.g. 256MB, 2GB, 16384kB.
#PG_SHARED_BUFFERS=4GB
#PG_EFFECTIVE_CACHE_SIZE=11GB
#PG_MAINTENANCE_WORK_MEM=1GB
#PG_AUTOVACUUM_WORK_MEM=256MB
#PG_WORK_MEM=16MB
#PG_MAX_WORKER_PROCESSES=8
#PG_MAX_PARALLEL_WORKERS=8
#PG_MAX_PARALLEL_WORKERS_PER_GATHER=4
#PG_MAX_PARALLEL_MAINTENANCE_WORKERS=4
#PG_RANDOM_PAGE_COST=1.1
#PG_EFFECTIVE_IO_CONCURRENCY=200
#PG_MIN_WAL_SIZE=1GB
#PG_MAX_WAL_SIZE=4GB
#PG_CHECKPOINT_COMPLETION_TARGET=0.9
# Left at the Postgres default (100) unless set. Paperclip uses 1-2 connections
# per instance; scale via pooling, not by inflating this.
#PG_MAX_CONNECTIONS=100
#
# Reshape the auto-tuner formulas (rarely needed):
#PG_TUNE_SHARED_BUFFERS_FRACTION=25          # % of RAM for shared_buffers
#PG_TUNE_SHARED_BUFFERS_FLOOR_MB=128
#PG_TUNE_SHARED_BUFFERS_CAP_MB=16384         # don't over-reserve very large boxes
#PG_TUNE_EFFECTIVE_CACHE_FRACTION=75         # % of RAM (planner hint)
#PG_TUNE_MAINTENANCE_WORK_MEM_CAP_MB=2048
#PG_TUNE_AUTOVACUUM_WORK_MEM_CAP_MB=256
#PG_TUNE_WORK_MEM_FLOOR_MB=4
#PG_TUNE_PARALLEL_PER_GATHER_CAP=4
#PG_TUNE_MAX_WAL_FLOOR_MB=512
#PG_TUNE_MAX_WAL_CAP_MB=8192
#
# Pretend the box has a different size — e.g. reserve RAM for the app container,
# which shares the host, without setting a docker mem_limit. Also handy to
# preview tuning for a hypothetical server.
#PG_TUNE_TOTAL_MEM_MB=8192
#PG_TUNE_TOTAL_CPUS=4
#
# Escape hatches:
#PG_TUNE_DISABLE=1        # start Postgres with stock image defaults, no tuning
#PG_TUNE_PRINT_ONLY=1     # print the computed settings and exit without starting
